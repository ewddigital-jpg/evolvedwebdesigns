# ==========================================================================
# .htaccess für evowebdesign.de
# SEO-Optimierung: Redirects, HTTPS, Duplicate Content Prevention
# ==========================================================================

# ----------------------------------------------------------------------
# HTTPS Redirect (alle HTTP-Anfragen auf HTTPS)
# ----------------------------------------------------------------------
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ----------------------------------------------------------------------
# www auf non-www Redirect (Canonical Domain)
# evowebdesign.de/index.html → evowebdesign.de/
# ----------------------------------------------------------------------
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# ----------------------------------------------------------------------
# Duplicate Content Prevention: index.html entfernen
# /index.html → /
# /subpage/index.html → /subpage/
# ----------------------------------------------------------------------
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /(.*)index\.html\ HTTP/
RewriteRule ^(.*)index\.html$ https://evowebdesign.de/$1 [R=301,L]

# ----------------------------------------------------------------------
# Trailing Slash für Verzeichnisse (optional, aber empfohlen)
# /about → /about/
# ----------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^(.*)$ https://evowebdesign.de/$1/ [L,R=301]

# ----------------------------------------------------------------------
# .html Extension entfernen (Clean URLs)
# /faq.html → /faq
# /leistungen.html → /leistungen
# ----------------------------------------------------------------------
# Externe Redirects (Browser sieht /leistungen)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.html\ HTTP/
RewriteRule ^([^.]+)\.html$ https://evowebdesign.de/$1 [R=301,L]

# Interne Rewrites (Server findet die .html Datei)
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)$ $1.html [L]

# ----------------------------------------------------------------------
# 404 Error Page (optional)
# ----------------------------------------------------------------------
ErrorDocument 404 /404.html

# ----------------------------------------------------------------------
# Security Headers (Bonus)
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
    # X-Frame-Options gegen Clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # X-Content-Type-Options gegen MIME-Sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # X-XSS-Protection
    Header always set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ----------------------------------------------------------------------
# Browser Caching (Performance)
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Bilder (1 Jahr)
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS & JavaScript (1 Monat)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    # Fonts (1 Jahr)
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    
    # HTML (keine Caching)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ----------------------------------------------------------------------
# GZIP Compression (Performance)
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>
