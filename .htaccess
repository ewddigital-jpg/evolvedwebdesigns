# ============================================================
#  EWD Security Headers – oben in .htaccess einfügen
#  Getestet für: Google Fonts, Formspree, WhatsApp, IONOS
# ============================================================

<IfModule mod_headers.c>

    # ── 1. HTTPS erzwingen (HSTS) ──────────────────────────
    # Browser merkt sich: Diese Seite ist immer HTTPS
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # ── 2. Clickjacking verhindern ─────────────────────────
    # Eure Seite kann nicht in einen iFrame eingebettet werden
    Header always set X-Frame-Options "SAMEORIGIN"

    # ── 3. MIME-Sniffing blockieren ────────────────────────
    # Browser führt Dateien nur als das aus, was sie wirklich sind
    Header always set X-Content-Type-Options "nosniff"

    # ── 4. Referrer-Policy ─────────────────────────────────
    # Beim Klick auf externe Links wird die volle URL nicht weitergegeben
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # ── 5. Permissions-Policy ──────────────────────────────
    # Kamera, Mikrofon, GPS etc. gesperrt – ihr braucht das nicht
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

    # ── 6. Content-Security-Policy (CSP) ───────────────────
    # Erlaubt: eigene Domain, Google Fonts, Formspree, WhatsApp
    # Alles andere wird blockiert
    Header always set Content-Security-Policy "\
        default-src 'self'; \
        script-src 'self' 'unsafe-inline'; \
        style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
        font-src 'self' https://fonts.gstatic.com; \
        img-src 'self' data:; \
        connect-src 'self' https://formspree.io; \
        frame-src 'none'; \
        object-src 'none'; \
        base-uri 'self'; \
        form-action 'self' https://formspree.io; \
    "

    # ── 7. XSS-Filter (ältere Browser) ────────────────────
    Header always set X-XSS-Protection "1; mode=block"

</IfModule>

# ============================================================
